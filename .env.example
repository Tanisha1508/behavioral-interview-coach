# Copy to .env and fill in. Never commit .env.
# All free-tier keys.

# Gemini via Google AI Studio (primary LLM for probing + grading)
GOOGLE_API_KEY=

# Groq (failover LLM on Gemini 429s)
GROQ_API_KEY=

# Launch-tier STT/TTS plugins
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# LiveKit (only needed for Cloud; console mode can run local)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
