{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PersonaParams",
  "type": "object",
  "required": ["persona_id", "display_name", "round_profile", "probe_mix",
               "intensity", "interrupt_eagerness", "interrupt_budget",
               "patience_ms", "time_budget_s"],
  "properties": {
    "persona_id": {"type": "string"},
    "display_name": {"type": "string"},
    "round_profile": {"type": "string"},
    "probe_mix": {
      "type": "object",
      "description": "sampling weights over eligible probe types; sums to 1",
      "additionalProperties": {"type": "number", "minimum": 0, "maximum": 1}
    },
    "intensity": {"type": "integer", "minimum": 1, "maximum": 5},
    "interrupt_eagerness": {"type": "number", "minimum": 0.2, "maximum": 2.0},
    "interrupt_budget": {"type": "integer", "minimum": 0, "maximum": 5},
    "patience_ms": {"type": "integer", "minimum": 200},
    "time_budget_s": {"type": "integer", "minimum": 30},
    "topic_emphasis": {"type": "array", "items": {"type": "string"}},
    "opening_style": {"type": "string"},
    "voice_preset": {"type": "string"},
    "speaking_rate": {"type": "number", "minimum": 0.5, "maximum": 1.5}
  }
}
